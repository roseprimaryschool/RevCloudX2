{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the RevCloud application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user account was created."
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Deck": {
      "title": "Deck",
      "description": "A collection of flashcards.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the deck."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this deck."
        },
        "name": {
          "type": "string",
          "description": "The name of the deck."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the deck."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the deck was created."
        }
      },
      "required": ["id", "userId", "name", "createdAt"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "A single flashcard with a front and back.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the flashcard."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this flashcard."
        },
        "deckId": {
          "type": "string",
          "description": "The ID of the deck this flashcard belongs to."
        },
        "front": {
          "type": "string",
          "description": "The front text of the flashcard."
        },
        "back": {
          "type": "string",
          "description": "The back text of the flashcard."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the flashcard was created."
        }
      },
      "required": ["id", "userId", "deckId", "front", "back", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/decks/{deckId}": {
      "schema": {
        "$ref": "#/entities/Deck"
      },
      "description": "Stores flashcard decks."
    },
    "/flashcards/{flashcardId}": {
      "schema": {
        "$ref": "#/entities/Flashcard"
      },
      "description": "Stores individual flashcards."
    }
  }
}
